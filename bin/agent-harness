#!/usr/bin/env python3
"""agent-harness CLI entry point.

Locates `core/` relative to this script and dispatches to core.cli.main.entry.
"""

from __future__ import annotations

import sys
from pathlib import Path

HERE = Path(__file__).resolve()
REPO_ROOT = HERE.parent.parent  # bin/ -> repo root
CORE_PARENT = REPO_ROOT  # core/ lives at repo root

sys.path.insert(0, str(CORE_PARENT))

try:
    from core.cli.main import entry  # noqa: E402
except ImportError as exc:
    print(f"ERROR: cannot import core.cli.main: {exc}", file=sys.stderr)
    print(f"       expected core/ at {CORE_PARENT}/core", file=sys.stderr)
    sys.exit(2)


if __name__ == "__main__":
    sys.exit(entry())
